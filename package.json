{
  "name": "fluxdb",
  "version": "1.0.0",
  "description": "A lightweight, in-memory JSON document database with a fluent SDK and interactive CLI.",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "bin": {
    "flux": "bin/flux.js"
  },
  "scripts": {
    "start:server": "ts-node src/server/app.ts",
    "start:cli": "ts-node src/cli/repl.ts",
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "database",
    "in-memory",
    "json",
    "document",
    "nosql",
    "fluxdb"
  ],
  "author": "Briam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gbria/fluxdb"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "express": "^5.2.1",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^3.0.7"
  }
}
